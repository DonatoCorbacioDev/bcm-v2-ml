# --- MySQL Connection ---
# Local (MySQL exposed on 3307 by docker-compose):
DB_URL=mysql+pymysql://bcm_user:bcm_password@localhost:3307/bcm

# Inside Docker Compose (internal network, service name mysql):
# DB_URL=mysql+pymysql://bcm_user:bcm_password@mysql:3306/bcm

# --- CORS ---
# Allowed browser origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000

# --- Ollama Agent ---
# Base URL of the local Ollama server (no data leaves the server)
OLLAMA_URL=http://localhost:11434

# Model to use for /agent/insights (must be pulled with `ollama pull <model>`)
OLLAMA_MODEL=llama3.2

# Timeout in seconds for the Ollama request (allow extra time for the first
# call after Ollama starts, when the model needs to be loaded into memory)
OLLAMA_TIMEOUT=120.0

# Language used for the generated natural-language report
REPORT_LANGUAGE=italian

# --- Internal API authentication ---
# Shared secret the backend must send as the X-Internal-Api-Key header on
# every request. Leave empty for local dev (check disabled); set a strong
# random value before exposing this service outside the backend's trusted
# network. Must match ML_INTERNAL_API_KEY in the backend and docker-compose.
INTERNAL_API_KEY=
