# --- MySQL Connection ---
# Local (MySQL exposed on 3307 by docker-compose):
DB_URL=mysql+pymysql://bcm_user:bcm_password@localhost:3307/bcm

# Inside Docker Compose (internal network, service name mysql):
# DB_URL=mysql+pymysql://bcm_user:bcm_password@mysql:3306/bcm

# --- CORS ---
# Allowed browser origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000

# --- Ollama Agent ---
# Base URL of the local Ollama server (no data leaves the server)
OLLAMA_URL=http://localhost:11434

# Model to use for /agent/insights (must be pulled with `ollama pull <model>`)
OLLAMA_MODEL=llama3.2

# Timeout in seconds for the Ollama request
OLLAMA_TIMEOUT=60.0

# Language used for the generated natural-language report
REPORT_LANGUAGE=italian
